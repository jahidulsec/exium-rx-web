generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  sap_id           String             @id @db.VarChar(6)
  password         String             @db.VarChar(255)
  role             user_role
  created_at       DateTime?          @default(now()) @db.Timestamp(0)
  updated_at       DateTime?          @default(now()) @db.Timestamp(0)
  mio              user_group[]       @relation("user_group_mio_sap_idTouser")
  rm               user_group[]       @relation("user_group_rm_sap_idTouser")
  zm               user_group[]       @relation("user_group_zm_sap_idTouser")
  sm               user_group[]       @relation("user_group_sm_sap_idTouser")
  gm               user_group[]       @relation("user_group_gm_sap_idTouser")
  user_information user_information[]
}

model user_group {
  id         String    @id @db.VarChar(21)
  mio_sap_id String    @db.VarChar(6)
  rm_sap_id  String    @db.VarChar(6)
  zm_sap_id  String    @db.VarChar(6)
  sm_sap_id  String    @db.VarChar(6)
  gm_sap_id  String    @db.VarChar(6)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  mio        user      @relation("user_group_mio_sap_idTouser", fields: [mio_sap_id], references: [sap_id], onDelete: Cascade, map: "user_group_relation_1")
  rm         user      @relation("user_group_rm_sap_idTouser", fields: [rm_sap_id], references: [sap_id], onDelete: Cascade, map: "user_group_relation_2")
  zm         user      @relation("user_group_zm_sap_idTouser", fields: [zm_sap_id], references: [sap_id], onDelete: Cascade, map: "user_group_relation_3")
  sm         user      @relation("user_group_sm_sap_idTouser", fields: [sm_sap_id], references: [sap_id], onDelete: Cascade, map: "user_group_relation_4")
  gm         user      @relation("user_group_gm_sap_idTouser", fields: [gm_sap_id], references: [sap_id], onDelete: Cascade, map: "user_group_relation_5")

  @@unique([mio_sap_id, rm_sap_id, zm_sap_id, sm_sap_id, gm_sap_id], map: "user_group_index_7")
  @@index([rm_sap_id], map: "user_group_relation_2")
  @@index([zm_sap_id], map: "user_group_relation_3")
  @@index([sm_sap_id], map: "user_group_relation_4")
  @@index([gm_sap_id], map: "user_group_relation_5")
}

model user_information {
  user_code     String    @id @db.VarChar(10)
  sap_id        String    @db.VarChar(6)
  full_name     String    @db.VarChar(150)
  designation   String    @db.VarChar(50)
  mobile        String?   @db.VarChar(14)
  email         String?   @db.VarChar(200)
  team          String?   @db.VarChar(2)
  area_code     String    @db.VarChar(10)
  area_name     String    @db.VarChar(50)
  sap_area_code String    @db.VarChar(8)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  user          user      @relation(fields: [sap_id], references: [sap_id], onDelete: Cascade, map: "user_information_user_fk")

  @@unique([user_code, sap_id], map: "user_information_index_3")
  @@index([sap_id], map: "user_information_user_fk")
}

enum user_role {
  mio
  rm
  superadmin
  zm
  sm
  gm
}
