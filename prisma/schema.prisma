generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  user_id                              String            @id @db.VarChar(6)
  password                             String            @db.VarChar(255)
  role                                 user_role
  created_at                           DateTime?         @default(now()) @db.Timestamp(0)
  updated_at                           DateTime?         @default(now()) @db.Timestamp(0)
  doctor_rx                            doctor_rx[]
  user_group_user_group_gm_codeTouser  user_group[]      @relation("user_group_gm_codeTouser")
  user_group_user_group_mio_codeTouser user_group?       @relation("user_group_mio_codeTouser")
  user_group_user_group_rm_codeTouser  user_group[]      @relation("user_group_rm_codeTouser")
  user_group_user_group_sm_codeTouser  user_group[]      @relation("user_group_sm_codeTouser")
  user_group_user_group_zm_codeTouser  user_group[]      @relation("user_group_zm_codeTouser")
  user_image                           user_image?
  user_information                     user_information?
}

model user_group {
  id                             Int       @id @default(autoincrement())
  mio_code                       String    @unique(map: "mio_unq") @db.VarChar(6)
  rm_code                        String    @db.VarChar(6)
  zm_code                        String    @db.VarChar(6)
  sm_code                        String    @db.VarChar(6)
  gm_code                        String    @db.VarChar(6)
  created_at                     DateTime? @default(now()) @db.Timestamp(0)
  updated_at                     DateTime? @default(now()) @db.Timestamp(0)
  user_user_group_gm_codeTouser  user      @relation("user_group_gm_codeTouser", fields: [gm_code], references: [user_id], onDelete: Cascade, map: "gm_fk")
  user_user_group_mio_codeTouser user      @relation("user_group_mio_codeTouser", fields: [mio_code], references: [user_id], onDelete: Cascade, map: "mio_fk")
  user_user_group_rm_codeTouser  user      @relation("user_group_rm_codeTouser", fields: [rm_code], references: [user_id], onDelete: Cascade, map: "rm_fk")
  user_user_group_sm_codeTouser  user      @relation("user_group_sm_codeTouser", fields: [sm_code], references: [user_id], onDelete: Cascade, map: "sm_fk")
  user_user_group_zm_codeTouser  user      @relation("user_group_zm_codeTouser", fields: [zm_code], references: [user_id], onDelete: Cascade, map: "zm_fk")

  @@index([gm_code], map: "gm_fk")
  @@index([rm_code], map: "rm_fk")
  @@index([sm_code], map: "sm_fk")
  @@index([zm_code], map: "zm_fk")
}

model user_information {
  user_code     String    @id @db.VarChar(10)
  sap_id        String    @db.VarChar(6)
  full_name     String    @db.VarChar(150)
  designation   String    @db.VarChar(50)
  mobile        String?   @db.VarChar(14)
  email         String?   @db.VarChar(200)
  team          String?   @db.VarChar(2)
  area_code     String    @db.VarChar(10)
  area_name     String    @db.VarChar(50)
  sap_area_code String    @db.VarChar(8)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  user          user      @relation(fields: [user_code], references: [user_id], onDelete: Cascade, map: "user_fk")

  @@unique([user_code, sap_id], map: "user_information_index_3")
  @@index([sap_id], map: "user_information_user_fk")
}

model doctor {
  id               Int         @id @default(autoincrement())
  dr_sl            String      @db.VarChar(6)
  dr_master_id     String      @db.VarChar(8)
  dr_child_id      String      @unique(map: "child_id_unq") @db.VarChar(8)
  pppp_id          String?     @db.VarChar(10)
  full_name        String      @db.VarChar(200)
  gender_idx       String?     @db.VarChar(2)
  degrees          String?     @db.VarChar(150)
  speciality       String?     @db.VarChar(50)
  chamber          String?     @db.VarChar(200)
  mobile           String?     @db.VarChar(14)
  sap_sm_area_code String      @db.VarChar(6)
  sm_area_name     String      @db.VarChar(50)
  sap_zone_code    String      @db.VarChar(6)
  zone_name        String      @db.VarChar(50)
  sap_region_code  String      @db.VarChar(6)
  region_name      String      @db.VarChar(50)
  sap_area_code    String      @db.VarChar(6)
  area_name        String      @db.VarChar(50)
  area_group       String      @db.VarChar(2)
  dr_class         String?     @db.VarChar(2)
  rxQty            Int?
  emp              String?     @db.VarChar(4)
  exm              String?     @db.VarChar(4)
  created_at       DateTime?   @default(now()) @db.Timestamp(0)
  updated_at       DateTime?   @default(now()) @db.Timestamp(0)
  doctor_rx        doctor_rx[]
}

model brand {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(100)
  created_at DateTime?   @default(now()) @db.Timestamp(0)
  updated_at DateTime?   @default(now()) @db.Timestamp(0)
  doctor_rx  doctor_rx[]
}

model doctor_rx {
  id         Int               @id @default(autoincrement())
  user_id    String            @db.VarChar(6)
  doctor_id  Int
  brand_id   Int
  quantity   Int
  rx_date    DateTime          @db.Timestamp(0)
  created_at DateTime?         @default(now()) @db.Timestamp(0)
  updated_at DateTime?         @default(now()) @db.Timestamp(0)
  status     doctor_rx_status? @default(pending)
  brand      brand             @relation(fields: [brand_id], references: [id], map: "doctor_rx_brand_fk")
  doctor     doctor            @relation(fields: [doctor_id], references: [id], map: "doctor_rx_relation_3")
  user       user              @relation(fields: [user_id], references: [user_id], map: "doctor_rx_user_fk")

  @@index([brand_id], map: "doctor_rx_brand_fk")
  @@index([doctor_id], map: "doctor_rx_relation_3")
  @@index([user_id], map: "doctor_rx_user_fk")
}

model user_image {
  user_id    String    @id @db.VarChar(6)
  file_path  String    @db.VarChar(200)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  file_name  String    @db.VarChar(100)
  user       user      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "user_image_relation_1")
}

enum user_role {
  mio
  rm
  superadmin
  zm
  sm
  gm
}

enum doctor_rx_status {
  pending
  approved
  disapproved
}
